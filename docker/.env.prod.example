# Copy to docker/.env and fill in real values before `docker compose up`.
# Never commit the populated .env.

# ---- Build metadata ----
APP_VERSION=prod

# ---- Container timezone ----
TZ=UTC

# ---- PostgreSQL (must match [database] in config.toml) ----
POSTGRES_USER=banglab2bb2c
POSTGRES_PASSWORD=__CHANGE_ME_GENERATE_WITH_openssl_rand__
POSTGRES_DB=banglab2bb2c

# ---- Operator contact (used by certbot for cert expiry notices) ----
